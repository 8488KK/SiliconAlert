// Create random turrets after 5 seconds (x: 126-132 and 127-133, y: 67 and 66)
Event(getOwnTime() > 5){
    _RT0:= 0;
    while(_RT0 < 7){
        _RT1:= GetRnd(1, 5);
        
        // Determine turret type based on random value
        if(_RT1 == 1) {_RT2:= TURRET_DPT_GUN;}
        if(_RT1 == 2) {_RT2:= TURRET_DPT_GUN;}
        if(_RT1 == 3) {_RT2:= TURRET_GAS_SHELL_LAUNCHER;}
        if(_RT1 == 4) {_RT2:= TURRET_ION_REFLECTOR;}
        if(_RT1 == 5) {_RT2:= TURRET_PARCHER;}
        
        ActCreatePlObj(PLAYER_3, AIREL_MYSELF, _RT2, 126 + _RT0, 67, 1, LOGO_3, "", 0, 100, VEFF_TELEPORT, 1,1);
        ActCreatePlObj(PLAYER_3, AIREL_MYSELF, _RT2, 127 + _RT0 + _RT1, 66, 1, LOGO_3, "", 0, 100, VEFF_TELEPORT, 1,1);
        
        _RT0:= _RT0 + 1;
    }
}

