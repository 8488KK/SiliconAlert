include<[_inc_path]\AiScript.dfn>;
include<[_inc_path]\AiScript.mcr>;
include<[_main_path]\Projects\Projects\Scripts\SiliconAlert\Constants\Consts.dfn>;

/*
Игроки
BO - PLAYER_1
WS - PLAYER_4
BO - PLAYER_7
Союзник игроков
WS - PLAYER_5

Вражеский ИИ
SI - PLAYER_3

Флаги
GL0 - Игрок 1 в игре
GL1 - Игрок 4 в игре
GL2 - Игрок 7 в игре
GL3 - брифинг окончен
GL4, GL5, GL6 - флаг, что игрок нашел ренегатов
_RT0, _RT1 - используются в EventsPlayBriefings.arb
*/

OpenArbiter("Arbiter Silicon Alert");

    OpenEvents();
        include<[_curr_path]\EventsEndMission.arb>;
        include<[_curr_path]\EventsSetRes.arb>;
        include<[_curr_path]\EventsDeadZone.arb>;
        include<[_curr_path]\EventsIntro.arb>;
        include<[_curr_path]\EventsSetTurretsSI.arb>;
        include<[_curr_path]\EventsInputPL.arb>;
        include<[_curr_path]\EventsPlayBriefings.arb>;
        include<[_curr_path]\EventsStartMainMission.arb>;
        include<[_curr_path]\EventsCheckKillPlObj.arb>;

        // Событие, которое отслеживает создание объектов у игроков 1, 5, 7 и присваивает им имена
        EventPlObjCreated(_PI0 == PLAYER_1 || _PI0 == PLAYER_5 || _PI0 == PLAYER_7)
        {
            // Присваиваем имя объекту в зависимости от номера игрока
            if (_PI0 == PLAYER_1)
            {
                ActSetName("Player_1", _PI5, _PI6, _PI7, 0);
            }
            if (_PI0 == PLAYER_5)
            {
                ActSetName("Player_5", _PI5, _PI6, _PI7, 0);
            }
            if (_PI0 == PLAYER_7)
            {
                ActSetName("Player_7", _PI5, _PI6, _PI7, 0);
            }
            
            // Опционально: можно добавить сообщение
            // actStringMess("Object created for player " + _PI0 + " and named appropriately.");
            ActLockEvent();
        };

    CloseEvents();
    //include<[_curr_path]\arbiter_pl1.arb>;
