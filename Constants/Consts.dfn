// Текст Интро 1 
INTRO_TURELS0 = "Квадрат сигма-11. Научно-исследовательская станция \"НИС-8\". Пост охраны \"ГП1\". Местное время 17:43 ";
INTRO_TURELS1 = "ПУНКТ УПРАВЛЕНИЯ ГИДРОПУШКИ";
INTRO_TURELS2 = "Джимми: Я уже запарился тут сидеть, когда наша смена закончится?";
INTRO_TURELS3 = "Рик: Не ной, осталось... Опа! Смотри, это же энерджайзер силикоидов. Что он тут делает?";
INTRO_TURELS4 = "Джимми: Чё, где!? Дай-ка я по нему ЖАХНУ!";
INTRO_TURELS5 = "Рик: Хороший выстрел, Джимми.";
INTRO_TURELS6 = "Джимми: Хе-хе-хе...";

INTRO_SHARK_TEXT0 = "ПУНКТ УПРАВЛЕНИЯ ПСИ-ЦЕНТРОМ";
INTRO_SHARK_TEXT1 = "Пит: Что это за звуки?";
INTRO_SHARK_TEXT2 = "Джон: Да опять Джимми и Рик по акулам стреляют, не обращай внимание.";
INTRO_SHARK_TEXT3 = "Пит: Пфф, дети. Джон, пришли ли отчеты о наблюдении за акулами из северной части Сердца океана?";
INTRO_SHARK_TEXT4 = "Джон: Да, Пит, вот они, дер... Какого...!";
//-----------------------------------------------------------------------------------------------

// Текст Интро 2
INTRO2_TEXT12 = "Научный центр наблюдения за акулами. Время 17:59";
INTRO2_TEXT13 = "Селезнёв: Центр вызывает НИС-8, приём."; //125
INTRO2_TEXT14 = "НИС-8: Пш-ш-ш..."; //125+100 = 225
INTRO2_TEXT15 = "Селезнёв: Пит! Чёрт возьми! Выйди на связь!"; //225+75 = 300
INTRO2_TEXT16 = "НИС-8: Пш-ш-ш..."; //300 + 125 = 425
INTRO2_TEXT17 = "Селезнёв: Бля, что там случилось!"; //425+50 = 475
INTRO2_TEXT18 = "Звонок в Штаб подводной безопасности. Время 18:05"; //475+100 = 575
INTRO2_TEXT19 = "Селезнёв: Командир Стуков, приём. Это Селезнёв, у нас ЧП."; //575 + 150 = 725
INTRO2_TEXT20 = "Командир: Стуков слушает. Что случилось, профессор?"; //725+150 = 875
INTRO2_TEXT21 = "Селезнёв: Мы потеряли связь с НИС-8. Я пытался связаться с Питом, но в ответ - только тишина. Пришлите своих парней для выяснения причин. У меня плохое предчувствие."; //1025
INTRO2_TEXT22 = "Командир Стуков: …только этого мне не хватало. Хорошо, у меня как раз новобранцы прошли обучение. Ждите, скоро будут."; //1300 + 300 = 1600
INTRO2_TEXT23 = "Селезнёв: Спасибо, командир."; //1600+75=1675
//--------------------------------------------------------------------------------------------------

