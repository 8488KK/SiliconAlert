PRESS_KEY_TEXT1 = "ДЛЯ НАЧАЛА МИССИИ";
PRESS_KEY_TEXT2 = "НАЖМИТЕ СОЧЕТАНИЕ КЛАВИШ Shift+Ctrl+Alt+F1";
